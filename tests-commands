# 1. Lint
npm run lint

# 2. Unit-Tests (Vitest)
npm test

# 3. E2E-Tests (Playwright) — Server müssen vorher laufen!
#    Backend starten (in separatem Terminal):
npm run start:backend:test

#    Frontend starten (in separatem Terminal):
npm run dev:test

#    Dann Playwright ausführen:
npx playwright test --reporter=list

# Einzelnen Test ausführen, z.B.:
npx playwright test tests/complete_bot_game.spec.js --reporter=list

# Mit Browser-UI (zum Debuggen):
npx playwright test --headed --reporter=list


# ─── PRODUKTIV-SYSTEM TESTEN ────────────────────────────────────────────────

# Playwright gegen das live-System ausführen (kein lokaler Server nötig).
# Die /test/p1 & /test/p2 Routen sind in Produktion deaktiviert — diese Tests werden ausgeschlossen:
$env:BASE_URL="https://playronda.ma"; npx playwright test --reporter=list --ignore-glob="**/test_scenario_integrity.spec.js" --ignore-glob="**/testmode_p2.spec.js"

# Nur einen einzelnen Test gegen Produktion ausführen, z.B.:
$env:BASE_URL="https://playronda.ma"; npx playwright test tests/complete_bot_game.spec.js --reporter=list

# Mit Browser-UI (sichtbar) gegen Produktion debuggen:
$env:BASE_URL="https://playronda.ma"; npx playwright test --headed --reporter=list --ignore-glob="**/test_scenario_integrity.spec.js" --ignore-glob="**/testmode_p2.spec.js"

# Hinweis: Die testmode_p2.spec.js Tests benötigen den /test/* Endpunkt
# und funktionieren nur gegen das Backend auf Railway (nicht gegen playronda.ma direkt).
# Für diese Tests die BASE_URL auf das Railway-Frontend setzen:
$env:BASE_URL="https://ronda-frontend-development.up.railway.app"; npx playwright test --reporter=list