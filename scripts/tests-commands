# 1. Lint
npm run lint

# 2. Unit-Tests (Vitest)
npm test

# 3. E2E-Tests (Playwright) — Server müssen vorher laufen!
#    Backend starten (in separatem Terminal):
npm run start:backend:test

#    Frontend starten (in separatem Terminal):
npm run dev:test

#    Dann Playwright ausführen:
npx playwright test --reporter=list

# Einzelnen Test ausführen, z.B.:
npx playwright test tests/complete_bot_game.spec.js --reporter=list

# Mit Browser-UI (zum Debuggen):
npx playwright test --headed --reporter=list


# ─── PRODUKTIV-SYSTEM TESTEN ────────────────────────────────────────────────

# Playwright gegen das live-System ausführen (kein lokaler Server nötig).
# Die /test/p1 & /test/p2 Routen sind in Produktion deaktiviert — nur relevante Tests ausführen:
$env:BASE_URL="https://playronda.ma"; npx playwright test tests/smoke.spec.js tests/multiplayer.spec.js tests/complete_bot_game.spec.js tests/complete_multiplayer_game.spec.js tests/play_again.spec.js tests/latency_benchmark.spec.js --reporter=list

# Nur einen einzelnen Test gegen Produktion ausführen, z.B.:
$env:BASE_URL="https://playronda.ma"; npx playwright test tests/complete_bot_game.spec.js --reporter=list

# Mit Browser-UI (sichtbar) gegen Produktion debuggen:
$env:BASE_URL="https://playronda.ma"; npx playwright test tests/smoke.spec.js tests/multiplayer.spec.js tests/complete_bot_game.spec.js tests/complete_multiplayer_game.spec.js tests/play_again.spec.js tests/latency_benchmark.spec.js --headed --reporter=list

# Hinweis: Die test_scenario_integrity & testmode_p2 Tests brauchen den /test/* Endpunkt
# und funktionieren nur lokal (mit npm run start:backend:test).
